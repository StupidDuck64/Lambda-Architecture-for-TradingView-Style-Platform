# ─── InfluxDB ────────────────────────────────────────────────────────────────
# Generate a strong token — any string works (used as InfluxDB admin API token)
INFLUX_TOKEN=change-me-to-a-strong-random-token
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=change-me
INFLUX_ORG=vi
INFLUX_BUCKET=crypto

# ─── MinIO ───────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=iceberg
POSTGRES_PASSWORD=change-me
POSTGRES_DB=iceberg_catalog

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ──── Dagster ────────────────────────────────────────────────────────────────────
DAGSTER_PG_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/dagster

# ─── HTTPS Automation (Let's Encrypt + DuckDNS) ─────────────────────────────
CERTBOT_DOMAIN=your-subdomain.duckdns.org
CERTBOT_EMAIL=you@example.com
CERTBOT_RENEW_INTERVAL_SECONDS=43200
NGINX_AUTO_RELOAD_ENABLE=1
NGINX_RELOAD_INTERVAL_SECONDS=21600

# DuckDNS settings: token from duckdns.org and subdomain without .duckdns.org
DUCKDNS_TOKEN=change-me
DUCKDNS_SUBDOMAINS=your-subdomain
DUCKDNS_UPDATE_INTERVAL_SECONDS=300